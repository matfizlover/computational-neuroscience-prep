        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "firing_rates = np.array([12.5, 14.2, 11.8, 13.5, 15.1, 12.0, 13.9, 14.8, 12.7, 14.5])\n",
        "\n",
        "number = len(firing_rates)\n",
        "print(number)\n",
        "mean = np.mean(firing_rates)\n",
        "SD  = np.sqrt(np.sum(((firing_rates - mean)**2)/ (number - 1)))\n",
        "\n",
        "SEM = SD / np.sqrt(number)\n",
        "\n",
        "print(mean)\n",
        "print(SD)\n",
        "print(SEM)\n",
        "\n",
        "CI_95 = SEM*1.96\n",
        "\n",
        "fig, ax = plt.subplots()\n",
        "ax.bar(x=1, height=mean, yerr = CI_95, color = \"darkblue\", capsize = 12)\n"
      ]
    }
